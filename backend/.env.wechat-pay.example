# qsd Admin backend environment template for real WeChat Pay integration
# Copy this file to a secure local env file or import these variables into your shell/session.
# Do not commit real secrets.

# Server
SERVER_PORT=8080

# Database
DB_URL=jdbc:mysql://127.0.0.1:3306/qsd_admin?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=Asia/Shanghai&characterEncoding=utf8
DB_USERNAME=root
DB_PASSWORD=change_me

# Flyway
FLYWAY_ENABLED=true
FLYWAY_BASELINE_ON_MIGRATE=true

# JWT
JWT_ISSUER=qsd-admin
JWT_SECRET=replace_with_base64_secret
JWT_EXPIRE_MINUTES=180

# WeChat Pay switch
WECHAT_PAY_MOCK_ENABLED=false

# WeChat Pay runtime
WECHAT_PAY_AUTO_REFRESH_PLATFORM_CERTIFICATES=true
WECHAT_PAY_CERTIFICATE_STORE_DIR=backend/certs/wechatpay
WECHAT_PAY_CERTIFICATE_REFRESH_HOURS=6

# Merchant display name
WECHAT_PAY_MERCHANT_NAME=Production Merchant

# Required real merchant config
WECHAT_PAY_APP_ID=wx_your_real_mini_program_appid
WECHAT_PAY_APP_SECRET=your_real_app_secret
WECHAT_PAY_MCH_ID=your_real_mch_id
WECHAT_PAY_NOTIFY_URL=https://your-domain.example.com/api/payment/callback/wechat
WECHAT_PAY_API_V3_KEY=your_32_char_api_v3_key
WECHAT_PAY_PRIVATE_KEY_PATH=E:/secure/wechatpay/apiclient_key.pem
WECHAT_PAY_MERCHANT_SERIAL_NO=your_merchant_serial_no
WECHAT_PAY_PLATFORM_CERTIFICATE_PATH=E:/secure/wechatpay/wechatpay_platform.pem
