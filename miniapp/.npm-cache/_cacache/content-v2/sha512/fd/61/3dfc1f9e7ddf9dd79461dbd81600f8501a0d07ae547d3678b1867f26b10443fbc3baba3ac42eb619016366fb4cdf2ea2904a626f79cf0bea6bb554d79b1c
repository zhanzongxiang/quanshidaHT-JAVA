ything less than 100% coverage will throw an error.\n","maintainers":[{"name":"jedmao","email":"jedmao@outlook.com"}],"time":{"modified":"2022-06-23T10:33:01.209Z","created":"2015-09-27T18:24:10.144Z","1.0.0":"2015-09-27T18:24:10.144Z","2.0.0":"2015-10-02T03:03:46.442Z","2.0.1":"2015-10-02T05:42:10.781Z","2.0.2":"2015-10-02T23:26:27.365Z","3.0.0":"2018-05-04T18:28:53.956Z","3.0.1":"2018-05-04T20:33:54.911Z","3.0.2":"2018-05-21T18:09:56.934Z","3.0.3":"2019-01-28T04:18:46.283Z","3.0.4":"2019-01-28T04:31:12.849Z","4.0.0":"2019-01-28T07:02:43.124Z"},"homepage":"https://github.com/jedmao/parse-css-font#readme","keywords":["css","parse","font","shorthand"],"repository":{"type":"git","url":"git+https://github.com/jedmao/parse-css-font.git"},"author":{"name":"Jed Mao","email":"jedmao@outlook.com"},"bugs":{"url":"https://github.com/jedmao/parse-css-font/issues"},"license":"MIT","readmeFilename":"README.md"}